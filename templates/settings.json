{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -f *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout .)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git branch -D*)",
      "Bash(git filter-branch*)",
      "Bash(git config core.hooksPath*)",
      "Bash(eval *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(mkfs.* *)",
      "Bash(docker exec *)",
      "Bash(devbox run *)",
      "Bash(bash -c *)",
      "Bash(zsh -c *)",
      "Bash(sh -c *)",
      "Bash(fish -c *)",
      "Bash(ksh -c *)",
      "Bash(dash -c *)",
      "Bash(python -m *)",
      "Bash(python3 -m *)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git update-ref *)",
      "Bash(git submodule deinit *)",
      "Bash(git gc --prune*)",
      "Bash(git reflog expire*)",
      "Bash(git reflog delete*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.kube/**)",
      "Read(.netrc)",
      "Read(~/.npmrc)",
      "Edit(./.env*)",
      "Edit(.github/workflows/**)",
      "Edit(.claude/**)",
      "Edit(.mcp.json)",
      "Edit(.husky/**)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(pnpm add*)",
      "Bash(yarn add*)",
      "Bash(pip install*)",
      "Bash(brew install*)",
      "Bash(npx -y *)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "effortLevel": "high",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/bash-guard.py" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/edit-write-guard.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/audit.py" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/session-start.py" }
        ]
      }
    ]
  }
}
